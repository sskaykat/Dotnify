{
  "name": "dotnify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aggregate and manage DNS resolution records across multiple domain registrars.",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev",
    "build": "tsc -b && vite build",
