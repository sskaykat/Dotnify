{
  "name": "dotnify",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Aggregate and manage DNS resolution records across multiple domain registrars.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "tsx server/start.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@upstash/redis": "^1.34.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
